# ═══════════════════════════════════════════════════════════
# Sanity Agent – Environment Variables
# ═══════════════════════════════════════════════════════════

# Gemini API Key (Google AI Studio)
GOOGLE_API_KEY=your_gemini_api_key_here

# Azure SQL Connection String (Database: Euphoria)
AZURE_SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:sanityia.database.windows.net,1433;Database=Euphoria;Uid=sanityAdmin;Pwd={your_password_here};Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# Backend Microservices URLs (local development)
USERS_SERVICE_URL=http://localhost:8081
SPECIALIST_SERVICE_URL=http://localhost:8082
DIARY_SERVICE_URL=http://localhost:8083
NOTIFICATIONS_SERVICE_URL=http://localhost:8085
